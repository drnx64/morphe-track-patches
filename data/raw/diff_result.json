                  "versions: +1 version, -1 version"
                ]
              },
              {
                "name": "Clear VIP resolution tip",
                "description": "Forces MemberResolutionBean.getVipResolutionTip() to always return Boolean.FALSE.",
                "changes": [
                  "description updated",
                  "versions: +1 version, -1 version"
                ]
              },
              {
                "name": "Spoof member active status",
                "description": "Forces MemberInfo.isActive() to always return true.",
                "changes": [
                  "description updated",
                  "versions: +1 version, -1 version"
                ]
              },
              {
                "name": "Spoof member days left",
                "description": "Forces MemberInfo.getDaysLeft() to return 3650 (10 years) and MemberInfo.getExpiryDate() to return '2035-12-31'. The UI shows 'Valid Until <expiryDate>' — patching getDaysLeft alone left the display null because the UI uses getExpiryDate(), not getDaysLeft().",
                "changes": [
                  "description updated",
                  "versions: +1 version, -1 version"
                ]
              },
              {
                "name": "Spoof member provider flags",
                "description": "Forces MemberProvider.e() (kv_is_pay_enable_member) and MemberProvider.f() (kv_is_skip_ad) to always return true. Renamed from c()/e() in v3.0.15 to e()/f() in v3.0.16.",
                "changes": [
                  "description updated",
                  "versions: +1 version, -1 version"
                ]
              },
              {
                "name": "Suppress newbie bonus dialog",
                "description": "Makes MemberProvider.z(F)V return immediately, suppressing the 'Claim 7-day trial / newbies bonus' ClaimMemberDialog popup. Renamed from w(F)V in v3.0.15 to z(F)V in v3.0.16.",
                "changes": [
                  "description updated",
                  "versions: +1 version, -1 version"
                ]
              },
              {
                "name": "Unlock member resolution",
                "description": "Forces MemberResolutionBean.isUnlock() to always return Boolean.TRUE.",
                "changes": [
                  "description updated",
                  "versions: +1 version, -1 version"
                ]
              }
            ]
          }
